# Neon PostgreSQL (serverless, free at https://neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Generate your own: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Get your free API key at https://api.vinmonopolet.no
# Register, subscribe to the "Open" product, and paste your key here:
VINMONOPOLET_API_KEY=

# --- Optional services -----------------------------------------------------
# The app works locally with everything below unset, but on Vercel you'll
# want at least BLOB_READ_WRITE_TOKEN and RESEND_API_KEY configured for
# file uploads and password-reset emails to actually work.

# Vercel Blob — file uploads (wine images, avatars). Create a Blob store in
# the Vercel dashboard and copy the read-write token here.
# https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=

# Resend (transactional email) — password-reset emails.
# Get your API key at https://resend.com/api-keys
# Without this, /api/forgot-password returns 500 and the reset link is
# printed to the server log instead of emailed.
RESEND_API_KEY=
# Must be a verified sender/domain in Resend. Falls back to "Uva
# <noreply@uva.no>" if unset, which Resend will reject.
EMAIL_FROM=

# Dev-only: enables the /dev/emails preview route. Leave unset (or set to
# "0") in production. Set to "1" on a Vercel preview branch to inspect
# email templates before merging.
ENABLE_EMAIL_PREVIEW=
