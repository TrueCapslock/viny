# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# sqlite
dev.db
dev.db-journal

# DCC
.developer-control-center/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# uploads
public/uploads/*
!public/uploads/.gitkeep

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# local QA artifacts from manual / per-run iterations --
# per-run logs (e.g. tests-output/baseline.log) and ad-hoc
# screenshot folders (e.g. tests-output/sidebar-qa) used by
# investigation scripts. The shipped e2e suite does not write
# here; only ad-hoc verification work does.
/tests-output/

# per-run playwright capture logs from the local regression
# runner. Re-written on every `npx playwright test` run; never
# committed. The shipped e2e suite does not write here either;
/.pw-all.log
/.pw-vinskapet.log
/.pw-lists.log
/.pw-layout.log
/.pw-merge.log

# ad-hoc runner script written during regression triage.
/.run-pw.sh
