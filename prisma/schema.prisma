generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SharedList {
  id        Int       @id @default(autoincrement())
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  members   SharedListMember[]
  wines     Wine[]
}

model SharedListMember {
  id           Int         @id @default(autoincrement())
  sharedListId Int
  userId       Int
  role         String      @default("member") // "admin" | "member"
  createdAt    DateTime    @default(now())

  sharedList   SharedList  @relation(fields: [sharedListId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sharedListId, userId])
}

model Wine {
  id        Int       @id @default(autoincrement())
  name      String
  producer  String
  vintage   Int?
  varietal  String?
  region    String?
  country   String?
  type      String?
  notes     String?
  image     String?
  inCellar  Boolean   @default(false)
  quantity  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tastings  Tasting[]
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sharedListId  Int?
  sharedList    SharedList? @relation(fields: [sharedListId], references: [id])
  suggestions   WineSuggestion[]
  inLists       ListWine[]
}

model List {
  id        Int       @id @default(autoincrement())
  name      String
  userId    Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  wines  ListWine[]

  @@index([userId])
}

model ListWine {
  listId   Int
  wineId   Int
  addedAt  DateTime  @default(now())

  list     List      @relation(fields: [listId], references: [id], onDelete: Cascade)
  wine     Wine      @relation(fields: [wineId], references: [id], onDelete: Cascade)

  @@id([listId, wineId])
  @@index([listId])
  @@index([wineId])
}

model Tasting {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  rating      Int?
  nose        String?
  palate      String?
  finish      String?
  foodPairing String?
  pricePaid   Float?
  location    String?
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  wineId      Int
  wine        Wine     @relation(fields: [wineId], references: [id], onDelete: Cascade)
}

model User {
  id        Int       @id @default(autoincrement())
  name      String?
  email     String    @unique
  password  String
  image       String?
  wineapiKey  String?
  // v0.12.0: OpenRouter free-vision OCR backend (Gemini Flash / Qwen-VL / Mistral OCR)
  // for the photo-identification flow. opt-in; tesseract.js remains the
  // no-key fallback.
  openRouterKey  String?
  visionModel    String?  @default("google/gemini-2.0-flash-exp:free")
  prefersBeer Boolean @default(false)
  isAdmin     Boolean @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  wines       Wine[]

  sentFriendships   Friend[]     @relation("SentFriendships")
  receivedFriendships Friend[]   @relation("ReceivedFriendships")
  ownedShares        ListShare[]           @relation("ListOwners")
  editorShares       ListShare[]           @relation("ListEditors")
  sharedListMembers  SharedListMember[]
  sentSuggestions    WineSuggestion[]      @relation("SentSuggestions")
  receivedSuggestions WineSuggestion[]     @relation("ReceivedSuggestions")
  lists              List[]
}

model WineSuggestion {
  id        Int      @id @default(autoincrement())
  fromUserId Int
  toUserId   Int
  message   String?
  wineId    Int?

  name      String
  producer  String
  vintage   Int?
  varietal  String?
  region    String?
  country   String?
  type      String?
  notes     String?
  image     String?

  status    String   @default("pending") // "pending" | "accepted" | "declined"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fromUser  User     @relation("SentSuggestions", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser    User     @relation("ReceivedSuggestions", fields: [toUserId], references: [id], onDelete: Cascade)
  wine      Wine?    @relation(fields: [wineId], references: [id])
}

model Friend {
  id          Int      @id @default(autoincrement())
  requesterId Int
  addresseeId Int
  status      String   @default("pending") // "pending" | "accepted"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester   User     @relation("SentFriendships", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User     @relation("ReceivedFriendships", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
}

model ListShare {
  id        Int      @id @default(autoincrement())
  ownerId   Int
  editorId  Int
  createdAt DateTime @default(now())

  owner     User     @relation("ListOwners", fields: [ownerId], references: [id], onDelete: Cascade)
  editor    User     @relation("ListEditors", fields: [editorId], references: [id], onDelete: Cascade)

  @@unique([ownerId, editorId])
}

model SiteSettings {
  id                Int     @id @default(1)
  beerModeDisabled  Boolean @default(false)
}
